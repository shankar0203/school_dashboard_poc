# Copy to api/.env on the server (gitignored). Values come from your RDS / Cognito.
# scripts/apply-config.sh generates this from config.values.

# --- runtime ---
NODE_ENV=production
PORT=4000
DEFAULT_SCHOOL_ID=1          # fallback tenant when a token has no custom:school_id

# --- database (RDS MySQL) ---
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=school_app
DB_USER=admin
DB_PASSWORD=your-db-password

# --- auth (Cognito) — REQUIRED in production ---
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS: comma-separated allow-list of web origins (no trailing slash) ---
# Use "*" only for local dev. In prod set your real domain(s).
CORS_ORIGIN=https://app.yourschool.example

# --- optional tuning ---
RATE_LIMIT_PER_MIN=120

# --- LOCAL DEV ONLY ---
# Set AUTH_DISABLED=true to run the API without Cognito (acts as full-access
# owner, single school). The server REFUSES to start if this is true while
# NODE_ENV=production.
# AUTH_DISABLED=true
