# Copy this file to  terraform.tfvars  and fill in your values.
# (terraform.tfvars is gitignored — never commit real secrets.)

aws_region = "ap-south-1"
project    = "school-app"

# An EC2 key pair that ALREADY EXISTS in the region above
# (EC2 → Key Pairs → Create key pair, download the .pem).
key_name = "my-keypair-name"

# Your current public IP as a /32 CIDR. Find it: https://checkip.amazonaws.com
# Example:
my_ip_cidr = "203.0.113.25/32"

# RDS master credentials
db_username = "admin"
db_password = "ChangeMe_Str0ngPassword"

# UI source on GitHub — cloned & built automatically on the EC2 at boot.
github_repo   = "https://github.com/your-username/school-app-poc.git"
github_branch = "main"
# If package.json is at the repo root, leave this empty.
# If you pushed a parent folder and the app is in a subfolder, set it, e.g. "school-app-poc".
app_subdir    = ""
